# =================================================================
# TXENEZA MOBILE - Exemplo de Configuração de Ambiente (.env)
# Copie este ficheiro para ".env" na mesma diretoria e preencha os valores.
# =================================================================

# --- Mapbox Tokens ---
# Token de Acesso Público para carregar os mapas e geocodificação
MAPBOX_ACCESS_TOKEN=pk.seu_token_publico_aqui

# Token Secreto de Downloads necessário para descarregar o SDK nativo no Android/iOS
MAPBOX_DOWNLOADS_TOKEN=sk.seu_token_secreto_de_downloads_aqui

# --- Inteligência Artificial ---
# Chave da API do Gemini (Google AI) para o assistente de conversação e para
# a classificação de fotos de denúncia (RF-010).
#
# ⚠️ SEGURANÇA: esta chave fica embutida no app compilado e é extraível por
# qualquer pessoa que descompacte o APK/IPA. Antes de publicar a app,
# restrinja esta chave no Google Cloud Console (Credentials -> a chave ->
# Application restrictions -> Android apps / iOS apps, com o package name
# com.example.txeneza_app + SHA-1 de assinatura). Ver README.md, secção
# "Segurança", para mais detalhes.
GEMINI_API_KEY=sua_chave_gemini_aqui

# --- Supabase Configurações ---
# URL do projeto Supabase e chave anónima para interações da app móvel
SUPABASE_URL=https://seu_projeto.supabase.co
SUPABASE_ANON_KEY=sua_chave_anonima_do_supabase_aqui
SUPABASE_DB_PASSWORD=sua_senha_de_banco_de_dados_aqui

# URL de ligação direta ao Banco de Dados (usado para migrações ou testes se necessário)
DATABASE_URL=postgresql://postgres:sua_senha_de_banco_de_dados_aqui@db.seu_projeto.supabase.co:5432/postgres

# --- Mapbox Styles ---
# Estilos customizados ou padrões do Mapbox a serem usados na app
MAPBOX_STYLE_NORMAL=mapbox://styles/tivanepaulo2/cmrovy6jx005q01qt1jb91owi
MAPBOX_STYLE_SATELLITE=mapbox://styles/mapbox/satellite-streets-v12
